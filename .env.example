APP_NAME=InternAgent API
APP_ENV=dev
APP_PORT=8000
LLM_PROVIDER=claude

POSTGRES_DB=internagent
POSTGRES_USER=intern
POSTGRES_PASSWORD=intern123
POSTGRES_PORT=5432

REDIS_PORT=6379
QDRANT_PORT=6333

DATABASE_URL=postgresql+psycopg2://intern:intern123@postgres:5432/internagent
NEXT_PUBLIC_API_BASE_URL=
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_JOBS_COLLECTION=jobs
QDRANT_RESUMES_COLLECTION=resumes
QDRANT_KNOWLEDGE_COLLECTION=knowledge_chunks
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com

CLAUDE_API_KEY=sk-local
CLAUDE_BASE_URL=http://172.21.6.82:11434/v
CLAUDE_MODEL=gemma4:26b
CLAUDE_TRANSPORT=ollama_generate
CLAUDE_TIMEOUT_SECONDS=120

SERPAPI_API_KEY=
APIFY_TOKEN=
ENABLE_GLOBAL_ATS=false
ENABLE_LIEPIN_MCP=false
LIEPIN_MCP_URL=https://open-agent.liepin.com/mcp/user
LIEPIN_MCP_TOKEN=
LIEPIN_MCP_TOOL_NAME=
LIEPIN_MCP_QUERIES=产品经理@北京;Java@北京;Java@上海;Java@深圳;后端开发@深圳;前端开发@上海;测试开发@杭州;算法工程师@北京;数据分析@上海;运营@杭州;市场@广州;销售@成都;财务@北京;人力资源@上海
LIEPIN_MCP_LIMIT_PER_QUERY=10
LIEPIN_MCP_TIMEOUT_SECONDS=30

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_DEFAULT_USER_EMAIL=admin@example.com
TELEGRAM_POLL_TIMEOUT_SECONDS=0
TELEGRAM_POLL_LIMIT=20
TELEGRAM_TIMEZONE=Asia/Shanghai
TELEGRAM_QUIET_START_HOUR=23
TELEGRAM_QUIET_END_HOUR=8
TELEGRAM_DAILY_PUSH_LIMIT=3
TELEGRAM_SAME_TYPE_COOLDOWN_HOURS=12
TELEGRAM_NOTIFICATION_TICK_SECONDS=300
TELEGRAM_BIND_CODE_TTL_MINUTES=10
HTTP_PROXY=http://host.docker.internal:7890
HTTPS_PROXY=http://host.docker.internal:7890
ALL_PROXY=http://host.docker.internal:7890
NO_PROXY=localhost,127.0.0.1,::1,api,frontend,nginx,postgres,redis,qdrant,host.docker.internal,172.21.6.82
